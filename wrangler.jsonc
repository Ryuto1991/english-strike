{
  "name": "english-strike",
  "main": "src/worker.js",
  "compatibility_date": "2026-03-25",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  },
  "triggers": {
    "crons": ["0 21 * * *"]
  },
  "vars": {
    "DAILY_PACK_WEBHOOK_URL": "https://example.com/api/refresh-daily-pack"
  }
}
